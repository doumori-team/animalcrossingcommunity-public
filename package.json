{
  "name": "animalcrossingcommunity",
  "version": "2.0.0",
  "private": true,
  "description": "Animal Crossing Community",
  "type": "module",
  "main": "src/server/server.js",
  "scripts": {
    "build": "react-router build --mode ${NODE_ENV:-development}",
    "serve": "node src/server/server.js",
    "update-init-scripts": "bash ci/update-init-scripts.sh",
    "update-copyback": "bash ci/update-copyback.sh",
    "lint": "node --max-old-space-size=4096 ./node_modules/eslint/bin/eslint.js src",
    "lint-fix": "./node_modules/eslint/bin/eslint.js --fix src",
    "typecheck": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc",
    "test": "vitest server common",
    "test-server": "vitest tests/server",
    "test-client": "vitest tests/common",
    "test-cloudfront": "vitest tests/cloudfront",
    "test-waf": "vitest tests/waf",
    "test-playwright": "playwright test",
    "coverage": "vitest server common --coverage",
    "maintenance": "node src/server/scripts/maintenance.cjs",
    "db:migrate": "node db/migrate.js",
    "docker:migrate": "docker compose exec app npm run db:migrate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.984.0",
    "@aws-sdk/s3-request-presigner": "^3.984.0",
    "@paypal/react-paypal-js": "^8.8.3",
    "@react-router/dev": "^7.17.0",
    "@react-router/express": "^7.17.0",
    "@react-router/node": "^7.17.0",
    "@sentry/node": "^10.38.0",
    "@traptitech/markdown-it-spoiler": "^1.1.6",
    "axios": "^1.16.0",
    "buffer-crc32": "^1.0.0",
    "compressorjs": "^1.2.1",
    "connect-pg-simple": "^10.0.0",
    "date-fns-tz": "^3.2.0",
    "dompurify": "^3.4.0",
    "express": "^4.22.2",
    "express-session": "^1.18.2",
    "ioredis": "^5.6.0",
    "isbot": "^5.1.25",
    "jsqr": "^1.4.0",
    "judoscale-express": "^2.0.11",
    "markdown-it": "^14.1.1",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-ins": "^4.0.0",
    "multer": "^2.1.1",
    "p-limit": "^7.3.0",
    "pg": "^8.16.0",
    "qrcode": "^1.5.4",
    "qs": "^6.14.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-photo-album": "^3.1.0",
    "react-router": "^7.17.0",
    "react-select": "^5.10.1",
    "recharts": "^2.15.2",
    "tributejs": "^5.1.3",
    "vite-plugin-pwa": "^1.1.0",
    "web-push": "^3.6.7",
    "ws": "^8.20.1",
    "yet-another-react-lightbox": "^3.22.0"
  },
  "engines": {
    "node": "24.x"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@faker-js/faker": "^9.6.0",
    "@playwright/test": "^1.56.1",
    "@stylistic/eslint-plugin": "^4.2.0",
    "@stylistic/eslint-plugin-js": "^4.2.0",
    "@stylistic/eslint-plugin-jsx": "^4.2.0",
    "@stylistic/eslint-plugin-ts": "^4.2.0",
    "@testing-library/react": "^16.3.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/dompurify": "^3.2.0",
    "@types/express-session": "^1.18.1",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-attrs": "^4.1.3",
    "@types/markdown-it-emoji": "^3.0.1",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.8.1",
    "@types/pg": "^8.15.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@typescript-eslint/parser": "^8.29.0",
    "@vitest/coverage-v8": "^3.1.1",
    "eslint": "^9.31.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "ioredis-mock": "^8.9.0",
    "jsdom": "^26.0.0",
    "sass": "^1.89.0",
    "supertest": "^7.1.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.0",
    "vite": "^6.4.2",
    "vitest": "^3.1.1"
  }
}
